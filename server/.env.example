# Copy to .env and fill in, or export in your shell.

# Which AI provider to use: "anthropic" (default) or "bedrock"
RUNWAY_PROVIDER=anthropic

# --- Direct Anthropic API (RUNWAY_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Amazon Bedrock (RUNWAY_PROVIDER=bedrock) ---
# Uses standard AWS credentials (env vars, ~/.aws profile, or an IAM role).
# No Anthropic API key needed in this mode.
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
